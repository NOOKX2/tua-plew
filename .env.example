# Database (PostgreSQL)
# Local dev with docker-compose: postgresql://fittogo:fittogo@localhost:5432/fittogo
# App container uses: postgresql://fittogo:fittogo@db:5432/fittogo
#
# Prisma CLI อ่านจาก .env (ไม่ใช่ .env.local)
# Local: localhost | Docker app container: ใช้ @db อัตโนมัติผ่าน docker-compose
DATABASE_URL="postgresql://fittogo:fittogo@localhost:5432/fittogo"

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Google OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
