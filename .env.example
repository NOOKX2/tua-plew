# Database (MongoDB Atlas) — ใช้ทั้ง Docker และ local scripts
# Atlas → Connect → Drivers → copy แล้วแทน <password>
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/fittogo?retryWrites=true&w=majority"

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Local dev
AUTH_URL=http://localhost:3000

# Production (Vercel → Settings → Environment Variables → Production)
# AUTH_URL=https://tua-plew.vercel.app

# Google OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# LINE Login / LINE OA (optional)
# LINE Developers Console → LINE Login channel → Callback URL:
#   http://localhost:3000/api/auth/callback/line
#   https://tua-plew.vercel.app/api/auth/callback/line
AUTH_LINE_ID=
AUTH_LINE_SECRET=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
